terraform {
  required_version = ">= 1.0"
  
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
  }

  backend "azurerm" {
    resource_group_name  = ""
    storage_account_name = ""
    container_name       = ""
    key                  = "tf-data-dp-900-dev.tfstate"
  }
}

provider "azurerm" {
  features {}

  subscription_id = var.subscription_id
}
